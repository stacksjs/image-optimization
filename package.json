{
  "name": "image-optimization",
  "type": "module",
  "version": "0.0.1",
  "description": "ImageOptimization — native-style image optimization app built with stx + Bun, using pure-TS image libraries",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "keywords": [
    "image",
    "optimization",
    "imageoptim",
    "stx",
    "bun",
    "desktop"
  ],
  "scripts": {
    "setup": "pantry install && bun install",
    "dev": "stx .",
    "dev:native": "stx . --native",
    "build": "stx build",
    "start": "stx start",
    "release:patch": "bunx --bun bumpx patch --yes",
    "release:minor": "bunx --bun bumpx minor --yes",
    "release:major": "bunx --bun bumpx major --yes"
  },
  "dependencies": {
    "@stacksjs/stx": "^0.2.21",
    "@stacksjs/ts-avif": "^0.1.0",
    "@stacksjs/ts-bmp": "^0.1.0",
    "@stacksjs/ts-png": "^0.1.2",
    "@stacksjs/ts-webp": "^0.1.0",
    "ts-gif": "^0.1.2",
    "ts-jpeg": "^0.3.1"
  }
}
