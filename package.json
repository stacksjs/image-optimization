{
  "name": "image-optimization",
  "type": "module",
  "version": "0.0.1",
  "description": "ImageOptimization — native-style image optimization app built with stx + Bun, using pure-TS image libraries",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "keywords": [
    "image",
    "optimization",
    "imageoptim",
    "stx",
    "bun",
    "desktop"
  ],
  "files": [
    "pages",
    "components",
    "optimize.ts",
    "stx.config.ts",
    "crosswind.config.ts",
    "deps.yaml",
    "README.md"
  ],
  "scripts": {
    "setup": "pantry install && bun install",
    "dev": "stx .",
    "dev:native": "stx . --native",
    "build": "stx build",
    "start": "stx start",
    "publish:patch": "bunx --bun bumpx patch --yes",
    "publish:minor": "bunx --bun bumpx minor --yes",
    "publish:major": "bunx --bun bumpx major --yes"
  },
  "dependencies": {
    "@stacksjs/stx": "^0.2.21",
    "ts-avif": "link:ts-avif",
    "ts-bmp": "link:ts-bmp",
    "ts-gif": "link:ts-gif",
    "ts-jpeg": "link:ts-jpeg",
    "ts-png": "link:ts-png",
    "ts-webp": "link:ts-webp"
  }
}
